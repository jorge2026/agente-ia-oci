# =============================================================================
# env.example — Variables de entorno para el Agente de IA en OCI
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env a git (está en .gitignore).
# =============================================================================

# --- OCI Autenticación (para desarrollo local / CI) ---
OCI_CLI_USER=ocid1.user.oc1..aaaaaaaa<PLACEHOLDER>
OCI_CLI_TENANCY=ocid1.tenancy.oc1..aaaaaaaa<PLACEHOLDER>
OCI_CLI_FINGERPRINT=aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99
OCI_CLI_KEY_FILE=~/.oci/oci_api_key.pem
OCI_CLI_REGION=us-chicago-1

# --- OCI Function — Runtime config ---
OCI_REGION=us-chicago-1
COMPARTMENT_ID=ocid1.compartment.oc1..aaaaaaaa<PLACEHOLDER>

# --- OCI Generative AI ---
# Obtener IDs disponibles con:
#   oci generative-ai model list --compartment-id $COMPARTMENT_ID --all
GENAI_MODEL_ID=ocid1.generativeaimodel.oc1.us-chicago-1.<PLACEHOLDER>
# Endpoint personalizado (opcional, por defecto se construye con la región)
GENAI_ENDPOINT=

# --- Parámetros del modelo ---
MAX_TOKENS=1024
TEMPERATURE=0.7

# --- Logging ---
LOG_LEVEL=INFO

# --- Desarrollo / Testing ---
# Activar mock de OCI GenAI para pruebas locales sin conexión a OCI
MOCK_GENAI=false

# --- Terraform (para CI/CD opcional) ---
TF_VAR_compartment_ocid=ocid1.compartment.oc1..aaaaaaaa<PLACEHOLDER>
TF_VAR_region=us-chicago-1
TF_VAR_subnet_id=ocid1.subnet.oc1.iad..aaaaaaaa<PLACEHOLDER>
TF_VAR_genai_model_id=ocid1.generativeaimodel.oc1.us-chicago-1.<PLACEHOLDER>
TF_VAR_function_image=us-chicago-1.ocir.io/<namespace>/agente-ia-oci/agente-ia:1.0.0
